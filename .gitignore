# ── GSD baseline (auto-generated) ──
.gsd-id
.bg-shell/

# ── Local MCP config (machine-specific, generated by setup-mcp.sh) ──
.mcp.json

# ── Binaries, Installers, & Large Data (Project Specific) ──
# Prevents large scripts like Miniconda3-latest-Linux-x86_64.sh
*.sh
*.exe
*.bin
*.pkg

# Prevents local data samples from bloating the repo
# Note: we use 0.1 sampling for local runs
*.parquet
*.csv
*.pdf
!data/samples/.gitkeep
