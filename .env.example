# Copy this file to .env and fill in your values.
# python-dotenv loads .env automatically when starting the auth server or gateway.

# --- Auth ---
JWT_SECRET=84b042c908b12063fed6efc573ebb3df83680154296dab14950de8cce2892c66

# --- Auth server (python -m mcp_agent_factory.auth serve) ---
HOST=0.0.0.0
AUTH_PORT=8001
LOG_LEVEL=info

# --- Gateway (python -m mcp_agent_factory.gateway.run) ---
PORT=8000
GATEWAY_URL=http://localhost:8000

# --- Bridge ---
AUTH_SERVER_URL=http://localhost:8001
# BRIDGE_CLIENT_ID=bridge                       # uncomment + set BRIDGE_CLIENT_SECRET for M2M OAuth flow
# BRIDGE_CLIENT_SECRET=replace-with-client-secret
# GATEWAY_TOKEN=                                # output of: python -m mcp_agent_factory.auth token
# When only JWT_SECRET is set (above), the bridge self-signs tokens — no auth server needed.

# --- Storage ---
# REDIS_URL=redis://localhost:6379             # uncomment to use real Redis; leave commented for FakeRedis (in-memory)
# AUTH_REDIS_URL=redis://localhost:6379       # defaults to REDIS_URL

# --- Kafka (optional — leave unset to disable) ---
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Dev flags ---
MCP_DEV_MODE=0    # set to 1 to disable auth checks during local dev
RELOAD=0          # set to 1 for uvicorn auto-reload
